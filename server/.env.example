# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# MongoDB Atlas connection string
# Sign up free at https://www.mongodb.com/atlas
# Create a free M0 cluster → Connect → Drivers → copy the URI below
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority

# Server port (Vite proxy expects 3001)
PORT=3001

# Allowed origin for CORS — set to your Netlify URL in production
# Local dev:
CLIENT_ORIGIN=http://localhost:9141
# Production:
# CLIENT_ORIGIN=https://your-portfolio.netlify.app

# Admin panel password (used by /api/admin/view)
DB_PASSWORD=your-admin-password
